[flake8]
max-line-length = 120
exclude =
    __pycache__,
    .git,
    .github,
    tests/,
    scanner_core/__pycache__,
    *.pyc
ignore =
    W503,
    W291,
    W293,
    E303,
    E302,
    W292,
    E241,
    E221
per-file-ignores =
    scanner_core/scanner.py: E501, W291, W293, E241
    scanner_core/crawler.py: E501
    scanner_core/pdf_exporter.py: E501
